Name: Format Quone file
Description: Format the active .Q file in place using `quonec fmt`.
Binding: addin_fmt_active
Interactive: false

Name: Format Quone file (check only)
Description: Run `quonec fmt --check` on the active .Q file.
Binding: addin_fmt_check_active
Interactive: false

Name: Build current Quone project
Description: Compile the active project's `src/` into `build/` and run roxygen2.
Binding: addin_build_project
Interactive: false
